{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-south-1:657672949684:table/employees",
        "arn:aws:dynamodb:ap-south-1:657672949684:table/employees/index/*",
        "arn:aws:dynamodb:ap-south-1:657672949684:table/business_metrics",
        "arn:aws:dynamodb:ap-south-1:657672949684:table/business_metrics/index/*",
        "arn:aws:dynamodb:ap-south-1:657672949684:table/audit_logs",
        "arn:aws:dynamodb:ap-south-1:657672949684:table/audit_logs/index/*"
      ]
    }
  ]
}
